#!/bin/sh
case "$1" in
  *.md)
    open -a "/Users/yikkai/Applications/Homo.app" "$@"
    ;;
  *)
    cmd="/opt/homebrew/bin/nvim"
    for arg in "$@"; do
      cmd="$cmd '$(printf "%s" "$arg" | sed "s/'/'\\\\''/g")'"
    done
    osascript -e "
      tell application \"Ghostty\"
        set cfg to new surface configuration
        set command of cfg to \"$cmd\"
        set t to terminal 1 of selected tab of front window
        split t direction right with configuration cfg
      end tell" > /dev/null 2>&1
    ;;
esac
